            <div class="main">
                <div class="container">
                    <div class="signup-content">
                        <div class="signup-img">
                            @*<img src="~/images/signup-img.jpg" alt="">*@
                        </div>
                        <div class="signup-form">
                            <form asp-route-returnUrl="@Model.ReturnUrl" method="post" class="register-form" id="register-form" enctype="multipart/form-data">
                                <div asp-validation-summary="All" class="text-danger"></div>
                                <h2 class="text-center">Create an Account</h2>
                                <div class="row example mb-lg-3"></div>
                                <div class="form-row">
                                    <div class="form-group col-sm-6">
                                        <label asp-for="Input.FirstName"></label>
                                        <input asp-for="Input.FirstName" class="form-control shadow" />
                                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-sm-6">
                                        <label asp-for="Input.LastName"></label>
                                        <input asp-for="Input.LastName" class="form-control shadow" />
                                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-group">
                                    <label asp-for="Input.TownId"></label>
                                    <select asp-for="Input.TownId" class="form-control shadow" asp-items="@this.townsService.GetAll()"></select>
                                    <span asp-validation-for="Input.TownId" class="text-danger"></span>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-radio">
                                    <div class="form-row">
                                        <label for="gender" class="radio-label">Gender :</label>
                                        <div class="col-sm-10">
                                            <div class="form-radio-item">
                                                <input type="radio" asp-for="Input.Gender" id="male" value="Male" checked class="form-check-input">
                                                <label for="male" class="form-check-label">Male</label>
                                                <span class="check"></span>
                                            </div>
                                            <div class="form-radio-item">
                                                <input type="radio" asp-for="Input.Gender" id="female" value="Female" class="form-check-input">
                                                <label for="female" class="form-check-label">Female</label>
                                                <span class="check"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-radio">
                                    <div class="form-row">
                                        <label for="role" class="radio-label">Role :</label>
                                        <div class="col-sm-10">
                                            <div class="form-radio-item">
                                                <input type="radio" asp-for="Input.Role" id="student" value="Student" checked class="form-check-input">
                                                <label for="student" class="form-check-label">Student</label>
                                                <span class="check"></span>
                                            </div>
                                            <div class="form-radio-item">
                                                <input type="radio" asp-for="Input.Role" id="teacher" value="Teacher" class="form-check-input">
                                                <label for="teacher" class="form-check-label">Teacher</label>
                                                <span class="check"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-row">
                                    <div class="form-group col-sm-6">
                                        <label asp-for="Input.PhoneNumber"></label>
                                        <input asp-for="Input.PhoneNumber" class="form-control shadow" />
                                        <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-sm-6">
                                        <label asp-for="Input.Email"></label>
                                        <input asp-for="Input.Email" class="form-control shadow" />
                                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-group">
                                    <label asp-for="Input.BirthDate"></label>
                                    <input asp-for="Input.BirthDate" class="form-control shadow" />
                                    <span asp-validation-for="Input.BirthDate" class="text-danger"></span>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-group">
                                    <label>Username</label>
                                    <input asp-for="Input.UserName" class="form-control shadow" />
                                    <span asp-validation-for="Input.UserName" class="text-danger"></span>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-group">
                                    <label asp-for="Input.Password"></label>
                                    <input asp-for="Input.Password" class="form-control shadow" />
                                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-group">
                                    <label asp-for="Input.ConfirmPassword"></label>
                                    <input asp-for="Input.ConfirmPassword" class="form-control shadow" />
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                </div>
                                <div class="row example mb-lg-1"></div>
                                <div class="form-group">
                                    <label asp-for="Input.Image"></label>
                                    <input asp-for="Input.Image" class="form-control shadow" />
                                    <span asp-validation-for="Input.Image" class="text-danger"></span>
                                </div>
                                <div class="row example mb-lg-5"></div>
                                <div class="form-submit col text-center">
                                    <input type="reset" value="Reset All" class="btn btn-primary rounded-pill half-width shadow" name="reset" id="reset" />
                                    <input type="submit" value="Submit Form" class="btn btn-primary rounded-pill half-width shadow" name="submit" id="submit" />
                                </div>
                                <div class="row example mb-lg-3"></div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

@section Scripts {
    <script src="vendor/jquery/jquery.min.js"></script>
    <script src="js/main.js"></script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-23581568-13"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'UA-23581568-13');
    </script>

    <partial name="_ValidationScriptsPartial" />
}
